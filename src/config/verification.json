{
  "verificationMethod": {
    "id": "verificationMethod",
    "type": "select",
    "name": "verificationMethod",
    "label": "Verification Method",
    "placeholder": "Select verification method",
    "value": "",
    "isRequired": true,
    "hasError": false,
    "errorMessage": "",
    "validationRules": {
      "required": {
        "value": true,
        "errorMessage": "Please select a verification method."
      }
    },
    "options": [
      { "value": "", "label": "Select verification method" },
      { "value": "sms", "label": "SMS" },
      { "value": "email", "label": "Email" },
      { "value": "portal", "label": "Portal" }
    ],
    "aria-label": "Verification Method",
    "aria-describedby": "verificationHelp"
  },

  "verificationCode": {
    "id": "verificationCode",
    "type": "text",
    "name": "verificationCode",
    "label": "Verification Code",
    "placeholder": "Enter 6-digit code",
    "value": "",
    "isRequired": true,
    "hasError": false,
    "errorMessage": "",
    "maxLength": 6,
    "validationRules": {
      "required": {
        "value": true,
        "errorMessage": "Verification code is required."
      },
      "pattern": {
        "value": "^\\d{6}$",
        "errorMessage": "Verification code must be exactly 6 digits."
      }
    }
  }
}
